# Discordの Developer Portal から取得してください
TOKEN=your_bot_token_here
APPLICATION_ID=your_application_id_here

# コマンドを特定のサーバーだけに即時反映したい場合は指定（開発時推奨）
# 省略するとグローバルコマンドとして登録されます（反映まで最大1時間程度）
GUILD_ID=your_guild_id_here

# Koyeb等のホスティングでポートを指定された場合はここを合わせる（省略時は3000）
PORT=3000

# ローカル開発などでkeep-alive用HTTPサーバーを起動したくない場合はfalseにする
KEEP_ALIVE=true
